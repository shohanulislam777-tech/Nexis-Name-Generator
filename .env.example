# ============================================================
# Nexis Backend — Environment Variables
# Copy this file to .env for local development.
# On Railway: set these in the service Variables tab.
# ============================================================

# PostgreSQL connection string (Railway provides this automatically
# when you attach a Postgres plugin — copy from Railway dashboard).
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/nexis

# JWT signing secret — used to sign admin session tokens.
# Generate a strong random value: openssl rand -hex 32
# NEVER use the default in production.
SESSION_SECRET=change-this-to-a-random-64-char-secret

# Set to "production" on Railway. Controls logging format and
# other runtime behavior.
NODE_ENV=production

# TCP port the Express server binds to.
# Railway injects this automatically — do NOT set it manually on Railway.
# Required locally: the server crashes on startup if PORT is missing.
PORT=8080
